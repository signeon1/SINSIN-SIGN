rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: inquiries
    // Document ID: auto-generated
    // Fields:
    //   - companyName: string (required)
    //   - contactName: string (required)
    //   - contactPhone: string (required)
    //   - address: string (optional)
    //   - signType: string (optional)
    //   - budgetAndSchedule: string (optional)
    //   - createdAt: timestamp (required)
    //   - userId: string (optional)
    //
    // Collection: portfolio
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - category: string (required)
    //   - imageUrl: string (required)
    //   - description: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - email: string (required)
    //   - role: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "signeon1@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    function hasRequiredFields(requiredFields) {
      return request.resource.data.keys().hasAll(requiredFields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= minLen && 
             request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) || 
             (request.resource.data[field] is string && 
              request.resource.data[field].size() >= minLen && 
              request.resource.data[field].size() <= maxLen);
    }

    // Domain Validators
    function isValidInquiry() {
      let allowedFields = ['companyName', 'contactName', 'contactPhone', 'address', 'signType', 'budgetAndSchedule', 'createdAt', 'userId'];
      let requiredFields = ['companyName', 'contactName', 'contactPhone', 'createdAt'];
      
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(requiredFields) &&
             isValidString('companyName', 1, 100) &&
             isValidString('contactName', 1, 100) &&
             isValidString('contactPhone', 1, 50) &&
             isValidOptionalString('address', 0, 200) &&
             isValidOptionalString('signType', 0, 100) &&
             isValidOptionalString('budgetAndSchedule', 0, 1000) &&
             request.resource.data.createdAt is timestamp &&
             (!( 'userId' in request.resource.data ) || 
               (isAuthenticated() && request.resource.data.userId == request.auth.uid));
    }

    function isValidPortfolioItem() {
      let allowedFields = ['title', 'category', 'imageUrl', 'description', 'createdAt'];
      let requiredFields = ['title', 'category', 'imageUrl', 'createdAt'];
      
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(requiredFields) &&
             isValidString('title', 1, 100) &&
             isValidString('category', 1, 50) &&
             isValidString('imageUrl', 1, 500) &&
             isValidOptionalString('description', 0, 2000) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidUser() {
      let allowedFields = ['email', 'role', 'createdAt'];
      let requiredFields = ['email', 'role', 'createdAt'];
      
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(requiredFields) &&
             isValidString('email', 5, 100) &&
             request.resource.data.role in ['admin', 'user'] &&
             request.resource.data.createdAt is timestamp;
    }

    // Rules
    match /inquiries/{inquiryId} {
      // Anyone can create an inquiry
      allow create: if isValidInquiry();
      // Only admins can read, update, delete
      allow read, update, delete: if isAdmin();
    }

    match /portfolio/{portfolioId} {
      // Anyone can read portfolio items
      allow read: if true;
      // Only admins can create, update, delete
      allow create: if isAdmin() && isValidPortfolioItem();
      allow update: if isAdmin() && isValidPortfolioItem();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile with 'user' role, admins can create any
      allow create: if isAuthenticated() && isValidUser() && 
                    ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      
      // Users can update their own profile but cannot change role, admins can update any
      allow update: if isAuthenticated() && isValidUser() && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
                    
      allow delete: if isAdmin();
    }
  }
}
